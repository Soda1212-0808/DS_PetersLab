scale_image=0.0004
scale_plot=0.0005
Color={'G','P','G','P','G','P','G','P','G'};
titles{8}='mod1';
titles{26}='mod2';
titles{22}='first day of mod2';
titles{9}='mixed A';
overlays={[4,7];[7,4];[4,4];[7,7]}
group_name={'VA','AV'}; % VA-1,AV-2
all_buf_data_each=cell(2,1);
all_buf_data=cell(2,1);
img_data1=cell(2,1);
all_peak_mean=cell(2,1);
all_peak_error=cell(2,1);
all_peak_mean_mix=cell(2,1);
all_peak_error_mix=cell(2,1);

