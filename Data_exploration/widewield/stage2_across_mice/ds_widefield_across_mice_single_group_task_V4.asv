clear all
clc
Path = 'D:\Data process\wf_data\';
master_U_fn = fullfile(plab.locations.server_path,'Lab', ...
    'widefield_alignment','U_master.mat');
load(master_U_fn);
load('C:\Users\dsong\Documents\MATLAB\Da_Song\DS_scripts_ptereslab\General_information\roi.mat')

surround_samplerate = 35;
surround_window_task = [-0.2,1];
t_task = surround_window_task(1):1/surround_samplerate:surround_window_task(2);
t_kernels=1/surround_samplerate*[-10:30];

Color={'B','R'};
n1_name='';n2_name='';
use_period=[];
use_t=[];
animals={};
groups={'Vp-Av','Av-Vp','Vp-Av-n','Av-Vp-n','Vp-Af','Vo-n-Vp','Vs-Vp','Va-Vp'};
workflow='task';

data_type={'raw','kernels'};
%used_data=1;  1 raw data; 2 kernels；3 kernels encode

select_group=1:2

all_data_image2=cell(2,1);
all_data_cross_day=cell(2,1);

for used_data=2
    for curr_state=1
        if curr_state==1
            task_boundary1=0;
            task_boundary2=0.2;
            state='stim';
        elseif curr_state==2
            task_boundary1=-0.1;
            task_boundary2=0.1;
            state='move';
        elseif curr_state==3
            task_boundary1=-0.1;
            task_boundary2=0.1;
            state='iti_move';
        elseif curr_state==4
            task_boundary1=-0.1;
            task_boundary2=0.1;
            state='all_move';
        elseif curr_state==5
            task_boundary1=-0.1;
            task_boundary2=0.1;
            state='reward';
        end

        period_task=find(t_task>task_boundary1&t_task<task_boundary2);
        period_kernels=find(t_kernels>task_boundary1&t_kernels<task_boundary2);
        wf_task_kernel=cell(length(select_group),1);
        for curr_group=select_group;
            wf_task_kernel{curr_group}=table;
            main_preload_vars = who;

            if curr_group==1
                animals{curr_group} = {'DS007','DS010','AP019','AP021','DS011','AP022'};n1_name='visual position';n2_name='audio volume';
            elseif curr_group==2
                animals{curr_group} = {'DS000','DS004','DS014','DS015','DS016'};n1_name='audio volume';n2_name='visual position';
            elseif curr_group==3
                animals{curr_group} = {'AP018','AP020'};n1_name='visual position';n2_name='audio volume';
            elseif curr_group==4
                animals{curr_group} = {'DS006','DS013'};n1_name='audio volume';n2_name='visual position';
            elseif curr_group==5
                animals{curr_group} = {'AP027','AP028','DS019','DS020','DS021'};n1_name='visual position';n2_name='audio frequency';
            elseif curr_group==6
                animals{curr_group} = {'AP027','AP028','AP029'};n1_name='visual opacity';n2_name='visual position';
            elseif curr_group==7
                animals{curr_group} = {'HA003','HA004','DS019','DS020','DS021'};n1_name='visual size up';n2_name='visual position';
            elseif curr_group==8
                animals{curr_group} = {'HA000','HA001','HA002'};n1_name='visual angle';n2_name='visual position';

            end
            wf_task_kernel{curr_group}.name=animals{curr_group}';


            % used_id=1:3;

            all_data_video=cell(length(animals{curr_group}),1);
            all_data_workflow_name=cell(length(animals{curr_group}),1);
            all_data_learned_day=cell(length(animals{curr_group}),1);
            matches=cell(length(animals{curr_group}),1);
            all_data_sim2move=cell(length(animals{curr_group}),1);
            use_t=[];
            use_period=[];

            for curr_animal=1:length(animals{curr_group})
                preload_vars = who;

                animal=animals{curr_group}{curr_animal};
                raw_data_task=load([Path  workflow '\' animal '_' workflow '.mat']);
                raw_data_behavior=load([Path   'behavior\' animal '_behavior'  '.mat']);

                [~, temp_idx] = ismember( raw_data_task.workflow_day,raw_data_behavior.workflow_day);
                % temp_p=raw_data_behavior.rxn_f_stat_p(temp_idx,:);


                temp_p=nan(length(raw_data_behavior.workflow_day),2);
                idx_v=ismember(raw_data_behavior.workflow_name,'visual position');
                idx_a=ismember(raw_data_behavior.workflow_name,{'audio volume','audio freque'});
                idx_m=ismember(raw_data_behavior.workflow_name,'mixed VA');

                temp_p(idx_v,1)= raw_data_behavior.rxn_l_mad_p(idx_v,1);
                temp_p(idx_a,1)=raw_data_behavior.rxn_l_mad_p(idx_a,1);
                temp_p(idx_m,:)= [raw_data_behavior.rxn_l_mad_p(idx_m,1)...
                    raw_data_behavior.rxn_l_mad_p(idx_m,2)];
                temp_p=temp_p(temp_idx,:);

                raw_data_task.learned_day=temp_p<0.01;

                all_data_sim2move{curr_animal} =raw_data_behavior.stim2move_med(temp_idx,:);


                temp_rxn_med=cellfun(@(x) mean(x,'omitnan'), raw_data_behavior.stim_on2off_times(temp_idx,:),'UniformOutput',true);
                % raw_data_task_single=load([Path  workflow '\' animal '_' workflow '_single_trial.mat']);






                if used_data==1

                    idx=cellfun(@(x) ~isempty(x)  ,raw_data_task.wf_px_task);
                    if curr_state==1
                        image_all(idx)=cellfun(@(x)  plab.wf.svd2px(U_master,x(:,:,ifelse(size(x,3)==4  ,1,[1 4]))),...
                            raw_data_task.wf_px_task(idx),'UniformOutput',false);
                    elseif curr_state==2
                        image_all(idx)=cellfun(@(x)  plab.wf.svd2px(U_master,x(:,:,ifelse(size(x,3)==4  ,2,[2 5]))),raw_data_task.wf_px_task(idx),'UniformOutput',false);
                    elseif curr_state==3
                        image_all(idx)=cellfun(@(x)  plab.wf.svd2px(U_master,x(:,:,ifelse(size(x,3)==4  ,4,7))),raw_data_task.wf_px_task(idx),'UniformOutput',false);

                    end

                    use_period=period_task;
                    use_t=t_task;
                elseif used_data==2
                    idx=cellfun(@(x) ~isempty(x),raw_data_task.wf_px_task_kernels);

                    image_all(idx)=cellfun(@(x)  plab.wf.svd2px(U_master(:,:,1:size(x{curr_state},1)),x{curr_state}),raw_data_task.wf_px_task_kernels(idx),'UniformOutput',false);
                    use_period=period_kernels;
                    use_t=t_kernels;
                elseif used_data==3
                    idx=cellfun(@(x) ~isempty(x),raw_data_task.wf_px_task_kernels);

                    % image_all(idx)=cellfun(@(x)  plab.wf.svd2px(U_master,permute(x(),[3,2,1])),raw_data_task.wf_px_task_kernels_encode(idx),'UniformOutput',false);

                    image_all(idx)=cellfun(@(x)...
                        ifelse(size(x,1)==3, plab.wf.svd2px(U_master,permute(x(curr_state,:,:),[3,2,1])), ...
                        plab.wf.svd2px(U_master,permute(x(2*curr_state-1:2*curr_state,:,:),[3,2,1])) ),...
                        raw_data_task.wf_px_task_kernels_encode(idx),'UniformOutput',false);


                    use_period=period_kernels;
                    use_t=t_kernels;
                end
                matches{curr_animal}=unique(raw_data_task.workflow_type_name_merge(idx)  ,'stable');

                all_data_video{curr_animal}=image_all(idx);
                all_data_workflow_name{curr_animal}=raw_data_task.workflow_type_name_merge(idx);
                all_data_learned_day{curr_animal}=raw_data_task.learned_day(idx,:);
                clearvars('-except',preload_vars{:});

            end

            if curr_state==3 |curr_state==4
                all_data_image=cell(8,1);
            else
                all_data_image=cell(9,1);
            end

            pre_learn_data0_idx=cellfun(@(y,z,l) ...
                find(strcmp(y,z(find(cellfun(@(idx) strcmp(n1_name, idx),z,'UniformOutput',true))))& l(:,1)==0 )...
                ,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);

            pre_learn_data1_idx = cellfun(@(y,z,l)...
                find(strcmp(y,z(find(cellfun(@(idx) strcmp(n1_name, idx),z,'UniformOutput',true))))& l(:,1)==0 ,2,'last')...
                ,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);

            post_learn1_data1_idx = cellfun(@(y,z,l)...
                find(strcmp(y,z(find(cellfun(@(idx) strcmp(n1_name, idx),z,'UniformOutput',true))))& l(:,1)==1 ,2,'first')...
                ,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);

            post_learn2_data1_idx = cellfun(@(y,z,l)...
                find(strcmp(y,z(find(cellfun(@(idx) strcmp(n1_name, idx),z,'UniformOutput',true))))& l(:,1)==1 ,5,'first')...
                ,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);
            post_learn2_data1_idx=cellfun(@(x) x(4:end),post_learn2_data1_idx,'UniformOutput',false);
            % post_learn2_data1_stim2move{curr_group} =cellfun(@(x,y) x(y)  ,all_data_sim2move,post_learn2_data1_idx,'UniformOutput',false);


            pre_learn_data2_idx = cellfun(@(y,z,l)...
                find(strcmp(y,z(find(cellfun(@(idx) strcmp(n2_name, idx),z,'UniformOutput',true))))& l(:,1)==0 ,2,'first')...
                ,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);

            post_learn1_data2_idx = cellfun(@(y,z,l) find(strcmp(y,z(find(cellfun(@(idx)...
                strcmp(n2_name, idx),z,'UniformOutput',true))))& l(:,1)==1 ,2,'first')...
                ,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);

            post_learn2_data2_idx = cellfun(@(y,z,l)...
                find(strcmp(y,z(find(cellfun(@(idx) strcmp(n2_name, idx),z,'UniformOutput',true))))& l(:,1)==1 ,5,'first')...
                ,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);
            post_learn2_data2_idx=cellfun(@(x) x(4:end),post_learn2_data2_idx,'UniformOutput',false);




            pre_learn_data0=cell(length(animals{curr_group}),1);
            pre_learn_data0 = cellfun(@(x,y,z,l) ...
                x(find(strcmp(y,z(find(cellfun(@(idx) strcmp(n1_name, idx),z,'UniformOutput',true))))& l(:,1)==0 ))...
                ,all_data_video,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);
            pre_learn_data0 = cellfun(@(x) x(1:end-2),pre_learn_data0,'UniformOutput',false);

            wf_task_kernel{curr_group}.mod1_naive=pre_learn_data0;

            pre_learn_data0 = cellfun(@(x) nanmean(cat(4,x{:}),4),pre_learn_data0,'UniformOutput',false);
            pre_learn_data0= cellfun(@(x) ...
                [x repmat({nan(450,426,length(use_t))},1,1-length(x))],pre_learn_data0,'UniformOutput',false);


            pre_learn_data1=cell(length(animals{curr_group}),1);
            pre_learn_data1 = cellfun(@(x,y,z,l) ...
                x(find(strcmp(y,z(find(cellfun(@(idx) strcmp(n1_name, idx),z,'UniformOutput',true))))& l(:,1)==0 ,2,'last'))...
                ,all_data_video,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);

            wf_task_kernel{curr_group}.mod1_pre_learn=pre_learn_data1;

            pre_learn_data1= cellfun(@(x) ...
                [x repmat({nan(450,426,length(use_t))},1,2-length(x))],pre_learn_data1,'UniformOutput',false);


            post_learn1_data1=cell(length(animals{curr_group}),1);
            post_learn1_data1 = cellfun(@(x,y,z,l)...
                x(find(strcmp(y,z(find(cellfun(@(idx) strcmp(n1_name, idx),z,'UniformOutput',true))))& l(:,1)==1 ,3,'first'))...
                ,all_data_video,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);

            wf_task_kernel{curr_group}.mod1_post_learn=post_learn1_data1;

            post_learn1_data1= cellfun(@(x)...
                [x  repmat({nan(450,426,length(use_t))},1,3-length(x))],post_learn1_data1,'UniformOutput',false);

            post_learn2_data1=cell(length(animals{curr_group}),1);
            post_learn2_data1 = cellfun(@(x,y,z,l)...
                x(find(strcmp(y,z(find(cellfun(@(idx) strcmp(n1_name, idx),z,'UniformOutput',true))))& l(:,1)==1 ,5,'first'))...
                ,all_data_video,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);
            post_learn2_data1 = cellfun(@(x) x(4:end),post_learn2_data1,'UniformOutput',false);

            wf_task_kernel{curr_group}.mod1_well_trained=post_learn2_data1;

            post_learn2_data1= cellfun(@(x) ...
                [x  repmat({nan(450,426,length(use_t))},1,2-length(x))],post_learn2_data1,'UniformOutput',false);


            pre_learn_data2=cell(length(animals{curr_group}),1);
            pre_learn_data2 = cellfun(@(x,y,z,l) x(find(strcmp(y,z(find(cellfun(@(idx) strcmp(n2_name, idx),z,'UniformOutput',true))))& l(:,1)==0 ,2,'first'))...
                ,all_data_video,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);

            wf_task_kernel{curr_group}.mod2_pre_learn=pre_learn_data2;

            pre_learn_data2= cellfun(@(x) [x  repmat({nan(450,426,length(use_t))},1,2-length(x))],pre_learn_data2,'UniformOutput',false);

            post_learn1_data2=cell(length(animals{curr_group}),1);
            post_learn1_data2 = cellfun(@(x,y,z,l) x(find(strcmp(y,z(find(cellfun(@(idx) strcmp(n2_name, idx),z,'UniformOutput',true))))& l(:,1)==1 ,3,'first'))...
                ,all_data_video,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);

            wf_task_kernel{curr_group}.mod2_post_learn=post_learn1_data2;

            post_learn1_data2= cellfun(@(x) [x repmat({nan(450,426,length(use_t))},1,3-length(x))],post_learn1_data2,'UniformOutput',false);


            post_learn2_data2=cell(length(animals{curr_group}),1);
            post_learn2_data2 = cellfun(@(x,y,z,l) x(find(strcmp(y,z(find(cellfun(@(idx) strcmp(n2_name, idx),z,'UniformOutput',true))))& l(:,1)==1 ,5,'first'))...
                ,all_data_video,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);
            post_learn2_data2 = cellfun(@(x) x(4:end),post_learn2_data2,'UniformOutput',false);

            wf_task_kernel{curr_group}.mod2_well_trained=post_learn2_data2;


            post_learn2_data2= cellfun(@(x) [x repmat({single(nan(450,426,length(use_t)))},1,2-length(x))],post_learn2_data2,'UniformOutput',false);

            first5day_data2=cell(length(animals{curr_group}),1);
            first5day_data2 = cellfun(@(x,y,z,l) x(find(strcmp(y,z(find(cellfun(@(idx) strcmp(n2_name, idx),z,'UniformOutput',true)))) ,5,'first'))...
                ,all_data_video,all_data_workflow_name,matches,all_data_learned_day,'UniformOutput',false);

            wf_task_kernel{curr_group}.mod2=first5day_data2;

            first5day_data2= cellfun(@(x) [x repmat({single(nan(450,426,length(use_t)))},1,5-length(x))],first5day_data2,'UniformOutput',false);

            % x=all_data_video{5};
            % y=all_data_workflow_name{5}
            % z=matches{5}
            % l=all_data_learned_day{5}

            n3_name='mixed VA';
            mixed_idx=cellfun(@(x) any(strcmp(n3_name, x)),matches ,'UniformOutput',true);
            data3=cell(length(animals{curr_group}),1);
            data3(mixed_idx) = cellfun(@(x,y,z) x(find(strcmp(y,z(find(cellfun(@(idx) strcmp(n3_name, idx),z,'UniformOutput',true)))),3,'last')),...
                all_data_video(mixed_idx) ,all_data_workflow_name(mixed_idx) ,matches(mixed_idx) ,'UniformOutput',false);

            wf_task_kernel{curr_group}.mix=data3;

            % itimvoe
            if curr_state==3 |curr_state==4
                data3(~mixed_idx) = arrayfun(@(x) repmat({nan(450,426,length(use_t),1)},1,3),...
                    (1:length(find(~mixed_idx)))', 'UniformOutput', false);
                data3= cellfun(@(x) [x  repmat({nan(450,426,length(use_t),1)},1,3-length(x))],data3,'UniformOutput',false);

                data_all=cellfun(@(a0,a,b,c,d,e,f,g,h) [a0 a b c d e f g h],pre_learn_data0, pre_learn_data1,post_learn1_data1,post_learn2_data1,...
                    pre_learn_data2,post_learn1_data2,post_learn2_data2,data3,first5day_data2,'UniformOutput',false);

                all_data_image{8}=cellfun(@(x) mean(cat(4,x{:}),4),data3,'UniformOutput',false);

            else
                data3(~mixed_idx) = arrayfun(@(x) repmat({nan(450,426,length(use_t),2)},1,3),...
                    (1:length(find(~mixed_idx)))', 'UniformOutput', false);
                data3= cellfun(@(x) [x  repmat({nan(450,426,length(use_t),2)},1,3-length(x))],data3,'UniformOutput',false);
                data3=cellfun(@(x)   cellfun(@(y) {y(:,:,:,1) ,y(:,:,:,2)} ,x,'UniformOutput',false),data3,'UniformOutput',false);
                data3= cellfun(@(x)   reshape([x{:}],1,6),data3,'UniformOutput',false);

                data_all=cellfun(@(a0,a,b,c,d,e,f,g,h) [a0 a b c d e f g([1 3 5]) g([2 4 6]) h],pre_learn_data0, pre_learn_data1,post_learn1_data1,post_learn2_data1,...
                    pre_learn_data2,post_learn1_data2,post_learn2_data2,data3,first5day_data2,'UniformOutput',false);

                all_data_image{8}=cellfun(@(x) mean(cat(4,x{[1 3 5]}),4,'omitnan'),data3,'UniformOutput',false);
                all_data_image{9}=cellfun(@(x) mean(cat(4,x{[2 4 6]}),4,'omitnan'),data3,'UniformOutput',false);

            end
            all_data_image{1}=cellfun(@(x) mean(cat(4,x{:}),4,'omitnan'),pre_learn_data0,'UniformOutput',false);

            all_data_image{2}=cellfun(@(x) mean(cat(4,x{:}),4,'omitnan'),pre_learn_data1,'UniformOutput',false);
            all_data_image{3}=cellfun(@(x) mean(cat(4,x{:}),4,'omitnan'),post_learn1_data1,'UniformOutput',false);
            all_data_image{4}=cellfun(@(x) mean(cat(4,x{:}),4,'omitnan'),post_learn2_data1,'UniformOutput',false);
            all_data_image{5}=cellfun(@(x) mean(cat(4,x{:}),4,'omitnan'),pre_learn_data2,'UniformOutput',false);
            all_data_image{6}=cellfun(@(x) mean(cat(4,x{:}),4,'omitnan'),post_learn1_data2,'UniformOutput',false);
            all_data_image{7}=cellfun(@(x) mean(cat(4,x{:}),4,'omitnan'),post_learn2_data2,'UniformOutput',false);



            all_data_image1= cellfun(@(x) cat(4,x{:}), all_data_image,'UniformOutput',false);
            all_data_image2{curr_group}{used_data,curr_state}=cat(5,all_data_image1{:});

    
            % all_data_cross_day{curr_group}{used_data}{curr_state}=data_all;
            all_data_cross_day{curr_group}{used_data}{curr_state} = ...
                feval(@(C) cat(5, C{:}), cellfun(@(x) cat(4, x{:}), data_all, 'UniformOutput', false));

            clearvars('-except',main_preload_vars{:});
            %
        end
    end
end

%
% all_data_cross_day:  1-3 pre learn1; 4-8 post learn; 9-10 pre learn2
% 11-15  post learn2;   16-21  mixed
% 22-26
% save(['D:\Data process\slide\papers\data\wf_task.mat' ],'wf_task_kernel','-v7.3')

%% task raw vs kernels


raw_v=permute(mean(max(all_data_image2{1}{1,1}(:,:,period_task,:,:,4),[],3),5),[1,2,4,3]);
kernels_v=permute(mean(max(all_data_image2{1}{2,1}(:,:,period_kernels,:,:,4),[],3),5,'omitnan'),[1,2,4,3]);
kernels_v_encode=permute(mean(max(all_data_image2{1}{3,1}(:,:,period_kernels,:,:,4),[],3),5,'omitnan'),[1,2,4,3]);


raw_a=permute(mean(max(all_data_image2{2}{1,1}(:,:,period_task,:,:,4),[],3),5,'omitnan'),[1,2,4,3]);
kernels_a=permute(mean(max(all_data_image2{2}{2,1}(:,:,period_kernels,:,:,4),[],3),5,'omitnan'),[1,2,4,3]);
kernels_a_encode=permute(mean(max(all_data_image2{2}{3,1}(:,:,period_kernels,:,:,4),[],3),5,'omitnan'),[1,2,4,3]);


raw_data={raw_v,raw_a};
kernels_data={kernels_v,kernels_a};
kernels_data_encode={kernels_v_encode,kernels_a_encode};

raw_across_time={mean(all_data_image2{1}{1,1}(:,:,:,:,:,4),5,'omitnan'),mean(all_data_image2{2}{1,1}(:,:,:,:,:,4),5,'omitnan')};

buf1=cellfun(@(x) reshape(x,size(x,1)*size(x,2),size(x,3)),raw_across_time,'UniformOutput',false) ;
buf3_roi_mean=cellfun(@(x) arrayfun(@(curr_roi) ...
    mean(permute(mean(x(roi1(curr_roi).data.mask(:),:,:),1),[2,3,1]),2,'omitnan'),...
    1:length(roi1),'UniformOutput',false),buf1,'UniformOutput',false);
buf3_roi_error=cellfun(@(x) arrayfun(@(curr_roi) ...
    std(permute(mean(x(roi1(curr_roi).data.mask(:),:,:),1,'omitnan'),[2,3,1]),0,2,'omitmissing')...
    ./sqrt(size(buf1{1},3)), 1:length(roi1),'UniformOutput',false),buf1,'UniformOutput',false);
line_colors={[
    0.7 0.7 1.0   % 浅蓝
    0.4 0.4 1.0   % 中浅蓝
    0.2 0.5 0.9   % 中深蓝
    0.0 0.2 0.5   % 深蓝
    ],[
    1.0 0.8 0.8   % 浅红（粉色）
    1.0 0.4 0.4   % 中浅红
    0.8 0.1 0.1   % 中深红
    0.5 0.0 0.0   % 深红
    ]}
% figure;
%
% for curr_group=1:2
%     nexttile
% for curr_area =1:4
% ap.errorfill(t_task,buf3_roi_mean{curr_group}{curr_area},buf3_roi_error{curr_group}{curr_area},line_colors{curr_group}(curr_area,:))
% xlim([0 0.4])
% end
% end

figure('Position',[50,50,290,600])
t2 = tiledlayout(3, 2, 'TileSpacing', 'tight', 'Padding', 'tight','TileIndexing', 'columnmajor');
colors={'B','R'}
titles={'visual','auditory'}
for curr_area=1:2
    a1=nexttile
    imagesc(raw_data{curr_area})
    axis image off
    ap.wf_draw('ccf',[0.5 0.5 0.5]);
    clim(0.02.*[0,1]);
    colormap(a1,ap.colormap(['W' colors{curr_area}]));
    axis image;
    colorbar('southoutside')
    title(titles{curr_area},'FontWeight','normal')

    a3=nexttile
    imagesc(kernels_data_encode{curr_area})
    axis image off
    ap.wf_draw('ccf',[0.5 0.5 0.5]);
    clim(0.01.*[0,1]);
    colormap(a3,ap.colormap(['W' colors{curr_area}]));
    axis image;
    colorbar('southoutside')


    a2=nexttile
    imagesc(kernels_data{curr_area})
    axis image off
    ap.wf_draw('ccf',[0.5 0.5 0.5]);
    clim(0.0005.*[0,1]);
    colormap(a2,ap.colormap(['W' colors{curr_area}]));
    axis image;
    colorbar('southoutside')





    switch curr_area
        case 1
            text(a1,-50, 150,  'raw', 'FontSize', 10, 'FontWeight', 'normal', ...
                'HorizontalAlignment', 'right', 'Rotation', 90);
            text(a2,-50, 150,  'decoding', 'FontSize', 10, 'FontWeight', 'normal', ...
                'HorizontalAlignment', 'right', 'Rotation', 90);
            text(a3,-50, 150,  'encoding', 'FontSize', 10, 'FontWeight', 'normal', ...
                'HorizontalAlignment', 'right', 'Rotation', 90);

    end

end



