        [0 0 0], [112  48 160]./255    ,[0 0 0]}
scale=0.0002;
type=2;
 figure('Position', [50 50 620 650]);
 t1 = tiledlayout(3, 4, 'TileSpacing', 'tight', 'Padding', 'tight');
 Color={'G','P','P','P','P','P','P'};
titles{1}='naive'; titles{5}='Mod1'; titles{8}='Mod2'; titles{9}='mixed';

