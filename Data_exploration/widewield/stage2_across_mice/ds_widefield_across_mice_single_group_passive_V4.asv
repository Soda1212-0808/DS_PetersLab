             % ylim(scale*[-0.4 1.2])
             ylim(scale*[0 1])

             title(roi1(curr_roi).name)
                xticks([2])
             xticklabels({'mixed'}); % 设置对应的标签
             ylabel('\Delta F/F')
         end

        

     end
 end
 

