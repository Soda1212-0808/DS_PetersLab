%% passive cross modality of 2 stage images and selectivity
colors{1}={[0 0 0],    [0 0 0],            [  84 130 53 ]./255;...
        [0 0 0], [0 0 0],    [112  48 160]./255}
colors{2}={[0 0 0],  [  84 130 53 ]./255  ,  [0.5 0.5 0.5]          ;...
        [0 0 0], [112  48 160]./255    ,[0.5 0.5 0.5]}
scale=0.0002;
type=2;
 figure('Position', [50 50 700 800]);
 t1 = tiledlayout(5, 5, 'TileSpacing', 'tight', 'Padding', 'tight');
 Color={'G','P','P','P','P','P','P'};
titles{1}='naive'; titles{5}='Mod1'; titles{8}='Mod2'; titles{9}='mixed';

all_buf_data=cell(2,1);
img_data1=cell(2,1)
buf3_roi_error_crossday=cell(2,1);
buf3_roi_mean_crossday=cell(2,1);
buf3_roi_l_mean_crosstime=cell(2,1);
buf3_roi_l_error_crosstime=cell(2,1);
buf3_roi_peak1=cell(2,1);
all_data_passive=cell(2,1);
all_buf_data_each=cell(2,1);
for curr_group=1:2
     for curr_passive=1:2
         if curr_passive==1
             use_stim=3;
         else
             use_stim=2;
         end

         for curr_stim=[ 1 5 8 ]
             a1=nexttile
             all_buf_data_each{curr_group}{curr_passive}{curr_stim}=...
                 permute(max(data_all_video{curr_group}{type}{curr_passive}...
                 (:,:,period_kernels,use_stim,:,curr_stim),[],3),[1 2 5 3 4]);
             temp_data=nanmean(data_all_video{curr_group}{type}{curr_passive}(:,:,:,use_stim,:,curr_stim),5);
             temp_image=max(temp_data(:,:,period_kernels),[],3);
             all_buf_data{curr_group}{curr_passive}{curr_stim}=temp_image;
             
             imagesc(temp_image)
             axis image off;
            colormap(a1,ap.colormap(['W' Color{curr_group}] ));
             clim(scale .* [0.3, 0.7]);

              frame1 = getframe(gca);
             img_data1{curr_group}{curr_passive}{curr_stim} =im2double( imresize(frame1.cdata, size(temp_image)));
             ap.wf_draw('ccf', 'black');
                          clim(scale .* [0, 1]);

             if curr_group==1& curr_passive==1
                title(titles{curr_stim})
             end

             if curr_passive==1&curr_stim==1
            text(-50, 50,  'V passive', 'FontSize', 10, 'FontWeight', 'bold', ...
                'HorizontalAlignment', 'right', 'Rotation', 90);
             elseif curr_passive==2&curr_stim==1
                 text(-50, 50,  'A passive', 'FontSize', 10, 'FontWeight', 'bold', ...
                'HorizontalAlignment', 'right', 'Rotation', 90);
             end


         end


         curr_data=cat(2 ,data_all{curr_group}{type}{curr_passive}{:});
         buf1= cellfun(@(x) reshape(x,size(x,1)*size(x,2),size(x,3),size(x,4)),curr_data,'UniformOutput',false) ;
         selected_roi=2*curr_passive-1;
         % selected_roi=[1 ]
         nexttile([1 2])
         hold on
         for curr_roi=1:length(roi1)

             buf3_roi_l=  cellfun(@(x) permute(nanmean(x(roi1(curr_roi).data.mask(:),:,:,:),1),[2,3,4,1]),buf1,'UniformOutput', false);
             buf3_roi_l_mean_crosstime{curr_group}{curr_passive}{curr_roi}= arrayfun(@(day) nanmean(cat(3,buf3_roi_l{day,:}),3),1:size(buf3_roi_l,1),'UniformOutput',false );
             buf3_roi_l_error_crosstime{curr_group}{curr_passive}{curr_roi}= arrayfun(@(day) std(cat(3,buf3_roi_l{day,:}),0,3,'omitmissing')./sqrt(size(cat(3,buf3_roi_l{day,:}),3)),1:size(buf3_roi_l,1),'UniformOutput',false );
             buf3_roi_l_mean= arrayfun(@(day) nanmean(cat(3,buf3_roi_l{day,:}),3),1:size(buf3_roi_l,1),'UniformOutput',false );

             all_data_passive{curr_group}{curr_passive}{curr_roi}=cat(3,buf3_roi_l_mean{:});
             buf3_roi_peak=cellfun(@(x) double(max(x(use_period,:),[],1) )',buf3_roi_l, 'UniformOutput', false);
             buf3_roi_peak1{curr_group}{curr_passive}{curr_roi}=reshape(cat(2,buf3_roi_peak{:}), [length(buf3_roi_peak{1}) size(buf3_roi_peak)]);
             buf3_roi_error_crossday{curr_group}{curr_passive}{curr_roi}=std(buf3_roi_peak1{curr_group}{curr_passive}{curr_roi},0,3,"omitmissing")./sqrt(size(buf3_roi_peak1{curr_group}{curr_passive}{curr_roi},3));
             buf3_roi_mean_crossday{curr_group}{curr_passive}{curr_roi}=nanmean(buf3_roi_peak1{curr_group}{curr_passive}{curr_roi},3);
         end

         for curr_roi=selected_roi
             for curr_stim=1:3
                 ap.errorfill(1:3,buf3_roi_mean_crossday{curr_group}{curr_passive}{curr_roi}(curr_stim,1:3),...
                     buf3_roi_error_crossday{curr_group}{curr_passive}{curr_roi}(curr_stim,1:3) ,colors{curr_passive}{curr_group,curr_stim},0.1,0.5);
                 ap.errorfill(4:11,buf3_roi_mean_crossday{curr_group}{curr_passive}{curr_roi}(curr_stim,4:11),...
                     buf3_roi_error_crossday{curr_group}{curr_passive}{curr_roi}(curr_stim,4:11) ,colors{curr_passive}{curr_group,curr_stim},0.1,0.5);

                 plot(1:3, permute(buf3_roi_peak1{curr_group}{curr_passive}{curr_roi}(use_stim,1:3,:),[2 3 1]),...
                     'Color',colors{curr_passive}{curr_group,use_stim})
                 plot(4:11, permute(buf3_roi_peak1{curr_group}{curr_passive}{curr_roi}(use_stim,4:11,:),[2 3 1]),...
                     'Color',colors{curr_passive}{curr_group,use_stim})
                 if curr_group==1
                     ap.errorfill(12:16,buf3_roi_mean_crossday{curr_group}{curr_passive}{curr_roi}(curr_stim,14:18),...
                         buf3_roi_error_crossday{curr_group}{curr_passive}{curr_roi}(curr_stim,14:18) ,colors{curr_passive}{curr_group,curr_stim},0.1,0.5);
                      
                     plot(12:16, permute(buf3_roi_peak1{curr_group}{curr_passive}{curr_roi}(use_stim,14:18,:),[2 3 1]),...
                         'Color',colors{curr_passive}{curr_group,use_stim})
                  
                     xlim([0.5 16.5])
                     xticks([2 7.5 14 ]); % 设置 y 轴的刻度位置（2代表naive stage中间位置，8代表stage1中间位置）

                 else
                     plot(12:18, permute(buf3_roi_peak1{curr_group}{curr_passive}{curr_roi}(use_stim,12:18,:),[2 3 1]),...
                         'Color',colors{curr_passive}{curr_group,use_stim})
                        ap.errorfill(12:18,buf3_roi_mean_crossday{curr_group}{curr_passive}{curr_roi}(curr_stim,12:18),...
                         buf3_roi_error_crossday{curr_group}{curr_passive}{curr_roi}(curr_stim,12:18) ,colors{curr_passive}{curr_group,curr_stim},0.1,0.5);
                      xlim([0.5 18.5])
                     xticks([2 7.5 15 ]); % 设置 y 轴的刻度位置（2代表naive stage中间位置，8代表stage1中间位置）
                 end
             end
             ylim(scale*[0 1])
             title(roi1(curr_roi).name)
             xticklabels({'naive','Mod 1','Mod 2'}); % 设置对应的标签
             ylabel('\Delta F/F')
         end
     end
 end

 
