curr_passive=1

image_idx=...
    find(cellfun(@(x) contains('stim_wheel_Vcenter_cross_movement_stage2_error_repeat',x),all_name{1, 1}  ,'UniformOutput',true));

image_all= cat(5,all_image{curr_passive}{image_idx});

image_mean=  permute(  nanmean(max(image_all(:,:,use_period,:,:),[],3),5),[1,2,4,3]
